# Copy this file to .env and fill in real values. NEVER commit the
# resulting .env file (it's already covered by ../../.gitignore's .env rule).

# Generate with: node ../scripts/generate-seed.js
# Capture stdout (the seed) and stderr (the recovery phrase) separately,
# e.g.: node ../scripts/generate-seed.js 1>seed.txt 2>phrase.txt
WALLET_SEED_ISSUER=

# Postgres superuser password for this stack's db container.
POSTGRES_PASSWORD=

# HashiCorp Vault dev root token. Generate with: openssl rand -hex 32
VAULT_DEV_ROOT_TOKEN_ID=

# Cloud Agent admin token. Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Pinned versions — current documented pairing per Identus's official
# Quick Start Guide as of this work.
AGENT_VERSION=2.0.0
PRISM_NODE_VERSION=2.6.0

API_KEY_ENABLED=true

# Cardano preprod connectivity — we'll come back to these once the basic
# stack is confirmed booting.
CARDANO_WALLET_ID=
CARDANO_PAYMENT_ADDRESS=