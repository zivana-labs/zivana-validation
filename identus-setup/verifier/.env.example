# Copy this file to .env and fill in real values. NEVER commit .env.
#
# Generate WALLET_SEED_VERIFIER with: node ../scripts/generate-seed.js
# Must be different from WALLET_SEED_ISSUER and WALLET_SEED_HOLDER.
WALLET_SEED_VERIFIER=

POSTGRES_PASSWORD=

# Generate with: openssl rand -hex 32
VAULT_DEV_ROOT_TOKEN_ID=

ADMIN_TOKEN=

AGENT_VERSION=2.2.0
PRISM_NODE_VERSION=2.6.0

API_KEY_ENABLED=true

POLLUX_DB_APP_USER=pollux-application-user
POLLUX_DB_APP_PASSWORD=password
CONNECT_DB_APP_USER=connect-application-user
CONNECT_DB_APP_PASSWORD=password
AGENT_DB_APP_USER=agent-application-user
AGENT_DB_APP_PASSWORD=password

# Cardano preprod connectivity — same as issuer setup.
# Verifier needs its own funded wallet for DID resolution.
CARDANO_WALLET_ID=
CARDANO_PAYMENT_ADDRESS=
